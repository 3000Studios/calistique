NODE_ENV=development
APP_NAME=calistique
API_MODE=repo-local
GH_BASE_BRANCH=main
GH_REPO=3000Studios/calistique
GH_TOKEN=replace-with-github-token
CLOUDFLARE_PAGES_PROJECT_NAME=calistique
SITE_URL=https://calistique.com
WWW_SITE_URL=https://www.calistique.com
SITE_ORIGIN=https://calistique.com
WWW_SITE_ORIGIN=https://www.calistique.com
ADMIN_API_ORIGIN=http://127.0.0.1:8787
ADMIN_EMAIL=admin@calistique.com
ADMIN_PASSCODE=5555
ADMIN_API_KEY=replace-with-strong-random-string
ADMIN_SESSION_SECRET=replace-with-long-random-session-secret
LOGS_ACCESS_CODE=8888
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUD_FLARE_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o
