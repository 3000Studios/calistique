OLLAMA_API_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
VITE_ENABLE_ADS=false
VITE_ADSENSE_CLIENT_ID=ca-pub-replace-me
ADSENSE_PUBLISHER_ID=pub-replace-me
VITE_CLOUDFLARE_WEB_ANALYTICS_TOKEN=replace-with-cloudflare-web-analytics-token
VITE_SITE_DISPLAY_NAME=Calistique
VITE_SITE_LEGAL_NAME=Calistique
VITE_SITE_DOMAIN=calistique.com
VITE_SITE_TITLE=Calistique | Luxury fashion and jewelry
VITE_SITE_DESCRIPTION=Premium fashion and jewelry drops with secure checkout and curated affiliate edits.
VITE_SITE_CATEGORY=Luxury fashion and jewelry commerce brand
VITE_SUPPORT_EMAIL=hello@calistique.com
PAYPAL_EMAIL=payments@calistique.com
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
