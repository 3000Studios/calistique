APP_NAME=myappai
API_MODE=repo-local
NODE_ENV=production
GH_BASE_BRANCH=main
GH_REPO=3000Studios/myappai
GH_TOKEN=replace-with-github-token
CLOUDFLARE_PAGES_PROJECT_NAME=myappai
SITE_URL=https://myappai.net
WWW_SITE_URL=https://www.myappai.net
SITE_ORIGIN=https://myappai.net
WWW_SITE_ORIGIN=https://www.myappai.net
# Must be an external repo-backed operator API, not this Pages URL.
ADMIN_API_ORIGIN=https://operator-api.example.com
ADMIN_EMAIL=admin@myappai.net
ADMIN_PASSCODE=5555
ADMIN_API_KEY=replace-with-strong-random-string
ADMIN_SESSION_SECRET=replace-with-long-random-session-secret
LOGS_ACCESS_CODE=8888
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o
# For Pages/edge this must be a public Ollama endpoint reachable from Cloudflare.
OLLAMA_API_URL=https://ollama.example.com
OLLAMA_MODEL=llama3.2:3b
OLLAMA_PROXY_SECRET=
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://myappai.net/api/public/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace-with-random-telegram-webhook-secret
TELEGRAM_ALLOWED_CHAT_IDS=
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_EMAIL=payments@myappai.net
PAYPAL_ENV=live
UNSPLASH_ACCESS_KEY=replace-with-unsplash-access-key
PEXELS_API_KEY=replace-with-pexels-api-key
PIXABAY_API_KEY=replace-with-pixabay-api-key
VITE_ENABLE_ADS=false
VITE_ADSENSE_CLIENT_ID=ca-pub-replace-me
VITE_GA4_MEASUREMENT_ID=
VITE_GTM_CONTAINER_ID=
VITE_META_PIXEL_ID=
VITE_CLARITY_PROJECT_ID=
CLAUDE_MODEL=claude-3-5-sonnet-latest
PUBLIC_ASSISTANT_PROVIDER=ollama
R2_PUBLIC_BASE_URL=
R2_BUCKET_NAME=myappai
R2_S3_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
