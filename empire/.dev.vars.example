CRYPTO_WALLET_VERIFY_TOKEN=

# Optional platform secrets
JWT_SIGNING_SECRET=
SESSION_SECRET=
DATABASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare service keys (if needed for scripts)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
