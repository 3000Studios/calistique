{
  "name": "campdreamga",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "prepare": "husky",
    "predev": "node scripts/generate-seo-assets.js",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:frontend\"",
    "dev:frontend": "vite",
    "dev:server": "node --watch server/index.js",
    "prebuild": "node scripts/generate-seo-assets.js",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "server": "node server/index.js",
    "deploy": "node scripts/deploy-site.js",
    "pages:deploy": "wrangler pages deploy dist --project-name campdreamga",
    "pages:dev": "wrangler pages dev dist",
    "command": "node scripts/run-command.js",
    "scheduler": "node ai/scheduler/aiScheduler.js",
    "traffic": "node scripts/run-traffic-cycle.js",
    "test": "node scripts/verify-platform.js && vitest run",
    "test:watch": "vitest",
    "validate:env": "node scripts/validate-environment.js",
    "analyze": "cross-env ANALYZE=true vite build",
    "ci": "npm run validate:env && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "campdreamga",
    "campdreamga.com",
    "camping",
    "georgia",
    "adsense-ready"
  ],
  "homepage": "https://campdreamga.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/3000Studios/voicetowebsite-copyright-mrjwswain.git"
  },
  "bugs": {
    "url": "https://github.com/3000Studios/voicetowebsite-copyright-mrjwswain/issues"
  },
  "author": "3000Studios",
  "license": "UNLICENSED",
  "description": "Camp Dream GA public site and admin manager for bookings, content, and deployment operations.",
  "lint-staged": {
    "*.{js,jsx,json,md,css}": [
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.36.0",
    "openai": "^6.29.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.5",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.1",
    "three": "^0.183.2",
    "vite": "^8.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.1",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.75.0"
  }
}
